# pg-ai-stewards — local stack configuration.
# Copy to .env and fill in. Every value has a default in docker-compose.yaml,
# so the stack also comes up with no .env at all (with no model provider and
# no personas wired).

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=stewards
POSTGRES_PASSWORD=stewards
POSTGRES_DB=stewards
# Host port for external psql/tooling (container port stays 5432).
PG_PORT=55434

# --- fs-read scope ----------------------------------------------------------
# A directory the substrate's research agents may read (mounted read-only at
# /workspace; the core fs-read seed further scopes within it). Defaults to an
# empty ./workspace.
# WORKSPACE_DIR=./workspace

# --- Model provider ---------------------------------------------------------
# The bgworker dispatches model calls. Set whatever your registered providers
# need (these names match the substrate's provider seeds; add your own in an
# overlay). Examples:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# For a local provider (LM Studio / Ollama) the bgworker reaches the host via
# host.docker.internal — no key needed.

# --- External-resource resolver (optional) ----------------------------------
# The substrate can fetch the content behind a citation (the 'resolve_ref'
# work kind) from an HTTP endpoint you configure. STEWARDS_RESOLVER_URL is a
# template: a "{ref}" placeholder is replaced with the url-encoded reference
# (if absent, the encoded ref is appended). The endpoint should return JSON.
# Read by the in-database bgworker, so it must reach the pg container's env
# (this .env does, via the pg service's env_file). Leave unset to disable.
# STEWARDS_RESOLVER_URL=https://example.com/api/get?ref={ref}
# STEWARDS_RESOLVER_TOKEN=

# --- Personas (only used under `--profile personas`) ------------------------
# Put a durable-mind persona in an ai-chattermax room. The persona key is a
# secret; CHATTERMAX_PERSONAS maps localSlug=key@roomId (comma-separated).
# CHATTERMAX_GATEWAY=wss://your-chattermax-host/gateway
# CHATTERMAX_PERSONAS=librarian=PERSONA_KEY@room-id
PERSONA_HOST_PORT=8091

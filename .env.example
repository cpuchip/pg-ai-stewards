# pg-ai-stewards — local stack configuration.
# Copy to .env and fill in. Every value has a default in docker-compose.yaml,
# so the stack also comes up with no .env at all (with no model provider and
# no personas wired).

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=stewards
POSTGRES_PASSWORD=stewards
POSTGRES_DB=stewards
# Host port for external psql/tooling (container port stays 5432).
PG_PORT=55434

# --- fs-read scope ----------------------------------------------------------
# A directory the substrate's research agents may read (mounted read-only at
# /workspace; the core fs-read seed further scopes within it). Defaults to an
# empty ./workspace.
# WORKSPACE_DIR=./workspace

# --- Model provider ---------------------------------------------------------
# The bgworker dispatches model calls. Set whatever your registered providers
# need. Providers bootstrap from STEWARDS_PROVIDER_<NAME>_{BASE_URL,API_KEY,
# DEFAULT_MODEL,KIND}. Full guide + a starter catalog: docs/wiring-up-models.md
# + examples/models.sql. Four examples (free → paid → local):
#
# opencode zen — free models out of the gate (deepseek-v4-flash-free) + Claude:
# STEWARDS_PROVIDER_OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
# STEWARDS_PROVIDER_OPENCODE_ZEN_API_KEY=
# opencode go — subscription tier (kimi/qwen/glm/minimax):
# STEWARDS_PROVIDER_OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# STEWARDS_PROVIDER_OPENCODE_GO_API_KEY=
# Google Gemini — your AI Studio key (OpenAI-compat endpoint):
# STEWARDS_PROVIDER_GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# STEWARDS_PROVIDER_GOOGLE_GEMINI_API_KEY=
# LM Studio — fully local, no key (reaches the host via host.docker.internal):
# STEWARDS_PROVIDER_LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
# STEWARDS_PROVIDER_LM_STUDIO_DEFAULT_MODEL=qwen/qwen3.6-27b

# --- External-resource resolver (optional) ----------------------------------
# The substrate can fetch the content behind a citation (the 'resolve_ref'
# work kind) from an HTTP endpoint you configure. STEWARDS_RESOLVER_URL is a
# template: a "{ref}" placeholder is replaced with the url-encoded reference
# (if absent, the encoded ref is appended). The endpoint should return JSON.
# Read by the in-database bgworker, so it must reach the pg container's env
# (this .env does, via the pg service's env_file). Leave unset to disable.
# STEWARDS_RESOLVER_URL=https://example.com/api/get?ref={ref}
# STEWARDS_RESOLVER_TOKEN=

# --- Coder (only used with -f docker-compose.coder.yaml) --------------------
# The sandbox coding capability. Read SECURITY.md first — the coder override
# mounts the host docker socket (host-root-equivalent). All of these are read
# bridge-side; none ever enters a sandbox.
#
# GITHUB_TOKEN: used for clone (private repos) + push + gh pr create. Supplied
# to git via a one-shot credential helper, never persisted or sent to a sandbox.
# GITHUB_TOKEN=
# Repos the coder may clone. DENY-ALL by default — nothing is clonable until
# you list it here (comma-separated substrings). Deny beats allow.
# CODER_REPO_ALLOWLIST=github.com/your-org/your-repo
# CODER_REPO_DENYLIST=github.com/your-org/private-secrets
# Commit author the coder uses (generic defaults if unset).
# CODER_GIT_AUTHOR_NAME=pg-ai-stewards coder
# CODER_GIT_AUTHOR_EMAIL=pg-ai-stewards-coder@users.noreply.github.com
# Sandbox image (default coder-runtime:latest). Build it from
# extension/coder-runtime.Dockerfile before first use.
# CODER_RUNTIME_IMAGE=coder-runtime:latest
# Network egress is ON by default (the agent pulls go mod / npm / pip). Set to
# off|none|false to force EVERY sandbox fully offline (--network=none) — do this
# for untrusted repos or an air-gapped posture.
# CODER_SANDBOX_NETWORK=off

# --- Personas (only used under `--profile personas`) ------------------------
# Put a durable-mind persona in an ai-chattermax room. The persona key is a
# secret; CHATTERMAX_PERSONAS maps localSlug=key@roomId (comma-separated).
# CHATTERMAX_GATEWAY=wss://your-chattermax-host/gateway
# CHATTERMAX_PERSONAS=librarian=PERSONA_KEY@room-id
PERSONA_HOST_PORT=8091
